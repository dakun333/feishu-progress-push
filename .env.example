# ============================================================
#  feishu-progress-push 配置示例
#  复制本文件为 .env 并填入你自己的真实值。
#
#  ⚠️  下面的 APP_ID / APP_SECRET 都是【假占位符】，必须替换！
#      不要把真实凭据提交进 git（.env 已被 .gitignore 忽略）。
# ============================================================

# ── 飞书应用凭据（必填）────────────────────────────────────
# 去飞书开放平台 https://open.feishu.cn 创建企业自建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Claude Code CLI ───────────────────────────────────────
# claude 可执行文件路径；若已在 PATH 中可保持默认 "claude"
# Windows 示例: %APPDATA%\npm\node_modules\@anthropic-ai\claude-code\bin\claude.exe
CLAUDE_CLI_PATH=claude
# 指定模型；留空 = 用 CLI 默认模型
CLAUDE_MODEL=
# Claude 的工作目录；留空 = 当前目录
CLAUDE_WORK_DIR=
# 额外授权目录（--add-dir），逗号分隔；留空则不加
CLAUDE_ADD_DIRS=

# ── 行为参数 ──────────────────────────────────────────────
# 单次任务超时（秒），超时后按 PID 结束该任务进程树
CLAUDE_TIMEOUT=300
# 进度节流间隔（秒），越大越不容易刷屏
PROGRESS_THROTTLE_SECONDS=5
# 是否加 --dangerously-skip-permissions（1=是 0=否）
CLAUDE_SKIP_PERMISSIONS=1

# ── 飞书 OpenAPI 基址（一般无需修改）──────────────────────
FEISHU_BASE_URL=https://open.feishu.cn
